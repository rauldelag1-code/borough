rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents ────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Personal listings
      match /listings/{listing} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Personal buildings
      match /buildings/{building} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Workspaces ────────────────────────────────────────────────────
    match /workspaces/{workspaceId} {
      // Allow create if the user is putting themselves in the members list
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;

      // Allow read if you're a member OR your email matches the pending invite
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        resource.data.pendingEmail == request.auth.token.email
      );

      // Allow update if you're a member, OR you're accepting an invite
      allow update: if request.auth != null && (
        // Existing member can update anything
        request.auth.uid in resource.data.members ||
        // Non-member accepting invite: their email matches pending, they add themselves
        (
          resource.data.pendingEmail == request.auth.token.email &&
          request.auth.uid in request.resource.data.members &&
          request.resource.data.members.size() <= 2
        )
      );

      // Only members can delete workspace
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Workspace listings
      match /listings/{listing} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.members;
      }

      // Workspace buildings
      match /buildings/{building} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.members;
      }
    }
  }
}
